{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoiceLink",
  "version": "0.1.0",
  "identifier": "com.voicelink.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "VoiceLink",
        "width": 900,
        "height": 650,
        "center": true,
        "resizable": true,
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "voicelink-tray",
      "iconPath": "icons/icon.png",
      "tooltip": "VoiceLink — AI TTS Engine"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../sapi_bridge/build/Release/voicelink_sapi.dll": "voicelink_sapi.dll",
      "../../server": "server/"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "./nsis/hooks.nsh",
        "startMenuFolder": "VoiceLink"
      }
    }
  }
}
